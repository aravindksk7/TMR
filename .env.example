# ── Jira / Xray ───────────────────────────────────────────────────────────────
JIRA_BASE_URL=https://your-org.atlassian.net
XRAY_BASE_URL=https://xray.cloud.getxray.app
# base64-encode "email@company.com:api_token" and paste the result here
# PowerShell: [Convert]::ToBase64String([Text.Encoding]::UTF8.GetBytes("email:token"))
# bash:       echo -n "email:token" | base64
JIRA_AUTH_TOKEN=<base64 of email:api_token>
# "2" for Jira Server/Data Center (on-premises), "3" for Jira Cloud
JIRA_API_VERSION=2
# "server" for Xray Server/DC REST API, "cloud" for Xray Cloud GraphQL
XRAY_VARIANT=server

# ── SQL Server ────────────────────────────────────────────────────────────────
STAGING_DB_DSN=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=Staging_DB;AutoCommit=True;
REPORTING_DB_DSN=DRIVER={ODBC Driver 18 for SQL Server};SERVER=localhost;DATABASE=Reporting_DB;AutoCommit=True;
# SQLAlchemy URL used by APScheduler job store
SCHEDULER_DB_URL=mssql+pyodbc://localhost/Staging_DB?driver=ODBC+Driver+18+for+SQL+Server

# ── Proxy (optional — required in on-premises environments with a corporate proxy)
# HTTP_PROXY=http://proxy.corp.com:8080
# HTTPS_PROXY=http://proxy.corp.com:8080
# NO_PROXY=localhost,127.0.0.1,.corp.com

# ── SSL (optional — set to corporate CA bundle when self-signed/internal certs are used)
# Either variable name is accepted: SSL_CERT_FILE or REQUESTS_CA_BUNDLE
# SSL_CERT_FILE=C:/certs/corporate-ca-bundle.pem
# REQUESTS_CA_BUNDLE=C:/certs/corporate-ca-bundle.pem

# ── Extraction ────────────────────────────────────────────────────────────────
MAX_RESULTS_PER_PAGE=100
RATE_LIMIT_RETRY_MAX=5
RATE_LIMIT_BACKOFF_BASE_MS=1000
# Comma-separated Jira project keys to include in extraction
JIRA_PROJECT_KEYS=PROJ1,PROJ2

# ── Custom field map ──────────────────────────────────────────────────────────
CUSTOM_FIELD_MAP_PATH=config/custom_field_map.json

# ── Scheduler cron expressions ────────────────────────────────────────────────
EXTRACTOR_CRON_HOUR=*/4
FULL_LOAD_CRON_HOUR=1

# ── Alerting (all optional) ───────────────────────────────────────────────────
# ALERT_WEBHOOK_URL=https://your-org.webhook.office.com/...
# ALERT_SMTP_HOST=smtp.your-org.com
# ALERT_SMTP_PORT=587
# ALERT_SMTP_USER=pipeline@your-org.com
# ALERT_SMTP_PASSWORD=<smtp-password>
# ALERT_SMTP_FROM=pipeline@your-org.com
# ALERT_SMTP_TO=qa-team@your-org.com,manager@your-org.com
