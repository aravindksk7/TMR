      {
        "name": "fact_requirement_coverage",
        "lineageTag": "bb239c45-876c-49a1-a6f2-aa58ecc4f74c",
        "measures": [
          {
            "name": "Total Requirements",
            "expression": "DISTINCTCOUNT('fact_requirement_coverage'[issue_sk])",
            "lineageTag": "cdcc6bdc-0b5c-4e18-8554-cb7c6f82f0d3"
          },
          {
            "name": "Covered Requirements",
            "expression": "CALCULATE(DISTINCTCOUNT('fact_requirement_coverage'[issue_sk]), 'fact_requirement_coverage'[is_covered] = TRUE())",
            "lineageTag": "66c6e271-dafa-4d91-a3dd-31e8a243a062"
          },
          {
            "name": "Coverage %",
            "expression": "DIVIDE([Covered Requirements], [Total Requirements], 0) * 100",
            "lineageTag": "44e244fc-a373-4ed9-b373-2252321abc99"
          },
          {
            "name": "Uncovered Requirements",
            "expression": "[Total Requirements] - [Covered Requirements]",
            "lineageTag": "81de0f6a-0329-463f-82ea-d153ae48569d"
          }
        ],
        "columns": [
          {
            "name": "issue_sk",
            "lineageTag": "64037560-7107-4175-aca9-9e5a0b65281f",
            "dataType": "int64",
            "sourceColumn": "issue_sk"
          },
