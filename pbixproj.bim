            "expression": "DIVIDE(SUM('vw_p8_release_snapshot'[passed_tests]), SUM('vw_p8_release_snapshot'[executed_tests]), 0) * 100",
            "lineageTag": "d0e1f2a3-b4c5-6789-defa-789012345679"
