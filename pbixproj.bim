      {
        "name": "fact_cycle_snapshot",
        "lineageTag": "a7b8c9d0-e1f2-3456-abcd-456789012345",
        "measures": [
          {
            "name": "Snapshot Pass Rate %",
            "expression": "DIVIDE(SUM('fact_cycle_snapshot'[passed_tests]), SUM('fact_cycle_snapshot'[executed_tests]), 0) * 100",
            "lineageTag": "a7b8c9d0-e1f2-3456-abcd-456789012346"
          },
          {
            "name": "Snapshot Coverage %",
            "expression": "DIVIDE(SUM('fact_cycle_snapshot'[covered_requirements]), SUM('fact_cycle_snapshot'[total_requirements]), 0) * 100",
            "lineageTag": "a7b8c9d0-e1f2-3456-abcd-456789012347"
          },
          {
            "name": "Snapshot Automation Rate %",
            "expression": "DIVIDE(SUM('fact_cycle_snapshot'[automated_executions]), SUM('fact_cycle_snapshot'[executed_tests]), 0) * 100",
            "lineageTag": "a7b8c9d0-e1f2-3456-abcd-456789012348"
          },
          {
            "name": "Snapshot Open Critical Defects",
            "expression": "SUM('fact_cycle_snapshot'[open_critical_defects])",
            "lineageTag": "a7b8c9d0-e1f2-3456-abcd-456789012349"
          }
