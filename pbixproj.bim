      {
        "name": "fact_test_run",
        "lineageTag": "6cf5da2f-e9bb-4bdc-ba72-dbeba18f5393",
        "measures": [
          {
            "name": "Total Runs",
            "expression": "COUNTROWS('fact_test_run')",
            "lineageTag": "d63da718-f1e9-447c-afa3-7b533a78b201"
          },
          {
            "name": "Passed Runs",
            "expression": "CALCULATE(COUNTROWS('fact_test_run'), 'fact_test_run'[run_status] = \"PASS\")",
            "lineageTag": "c9add60e-f5ea-47cf-ad54-9ada09ef4870"
          },
          {
            "name": "Failed Runs",
            "expression": "CALCULATE(COUNTROWS('fact_test_run'), 'fact_test_run'[run_status] = \"FAIL\")",
            "lineageTag": "f717f385-4553-4b67-ae08-ec8234513807"
          },
          {
            "name": "Blocked Runs",
            "expression": "CALCULATE(COUNTROWS('fact_test_run'), 'fact_test_run'[run_status] = \"BLOCKED\")",
            "lineageTag": "e4ad35c5-4422-4693-9e5f-c4f424e2e4a9"
          },
          {
            "name": "Pass Rate %",
            "expression": "DIVIDE([Passed Runs], [Total Runs], 0) * 100",
            "formatString": "0.0",
            "lineageTag": "d1f283f7-6bfc-441c-85e5-246a71b4c3a1"
          },
          {
            "name": "Avg Duration (seconds)",
            "expression": "AVERAGE('fact_test_run'[duration_s])",
            "lineageTag": "d9857779-3c34-4078-9083-73a407044f6c"
          },
          {
            "name": "Avg Duration (minutes)",
            "expression": "DIVIDE([Avg Duration (seconds)], 60, BLANK())",
            "lineageTag": "c8c570be-004a-482c-ba8b-f236fb54f129"
          },
          {
            "name": "Total Test Time (hours)",
            "expression": "DIVIDE(SUMX('fact_test_run', 'fact_test_run'[duration_s]), 3600, 0)",
            "lineageTag": "9d157257-d9f5-46c4-bbab-f8224ac19e88"
          },
          {
            "name": "Pass Rate (formatted)",
            "expression": "FORMAT([Pass Rate %], \"0.0\") & \"%\"",
            "lineageTag": "a255b0bb-78c9-436f-aee2-34b7cf75717a"
          },
          {
            "name": "P1 Target Pass Rate %",
            "expression": "80",
            "lineageTag": "e9564a36-e47e-4fce-ac49-9b8bab246ac7"
          },
          {
            "name": "Pass Rate % Prior Month",
            "expression": "CALCULATE([Pass Rate %], DATEADD('dim_date'[full_date], -1, MONTH))",
            "lineageTag": "5e123c1d-2c4d-468c-9b36-cffe804964d9"
          },
          {
            "name": "Pass Rate % Change",
            "expression": "[Pass Rate %] - [Pass Rate % Prior Month]",
            "lineageTag": "695694c3-5c7d-4afc-88b8-8fbff2a39462"
          },
          {
            "name": "Pass Rate % Change (formatted)",
            "expression": "VAR delta = [Pass Rate % Change] RETURN IF(ISBLANK(delta), \"-\", IF(delta >= 0, \"+\" & FORMAT(delta, \"0.0\") & \"%\", FORMAT(delta, \"0.0\") & \"%\"))",
            "lineageTag": "94b9eac2-39ec-4269-b13e-c07d9ae47a7f"
          },
          {
            "name": "P1 Pass Rate Status",
            "expression": "IF([Pass Rate %] >= [P1 Target Pass Rate %], \"On Track\", \"At Risk\")",
            "lineageTag": "9ffc4d8c-f60f-4923-8b53-893a13eb730a"
          },
          {
            "name": "Automated Runs",
            "expression": "CALCULATE(COUNTROWS('fact_test_run'), 'fact_test_run'[is_automated] = TRUE())",
            "lineageTag": "b9a8c7d6-e5f4-3a2b-1c0d-ef9876543210"
          },
          {
            "name": "Automation Rate %",
            "expression": "DIVIDE([Automated Runs], [Total Runs], 0) * 100",
            "lineageTag": "b9a8c7d6-e5f4-3a2b-1c0d-ef9876543211"
          }
        ],
