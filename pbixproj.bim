      {
        "name": "dim_defect",
        "lineageTag": "6c436db5-617e-4192-aef6-576a4fab72e8",
        "measures": [
          {
            "name": "Total Defects",
            "expression": "COUNTROWS('dim_defect')",
            "lineageTag": "ed269e0a-a3ef-4f02-b419-9b735dfeeea1"
          },
          {
            "name": "Open Defects",
            "expression": "CALCULATE(COUNTROWS('dim_defect'), NOT 'dim_defect'[status] IN {\"Closed\", \"Done\", \"Resolved\", \"Won't Fix\"})",
            "lineageTag": "1ea0f379-de13-475a-a255-a143d5608b8d"
          },
          {
            "name": "Critical Defects",
            "expression": "CALCULATE(COUNTROWS('dim_defect'), 'dim_defect'[severity] = \"Critical\" || 'dim_defect'[priority] IN {\"P0\", \"P1\", \"Highest\"})",
            "lineageTag": "32dc796b-eca7-4bc5-a9ff-b75a3ac495bf"
          },
          {
            "name": "Open Critical Defects",
            "expression": "CALCULATE(COUNTROWS('dim_defect'), NOT 'dim_defect'[status] IN {\"Closed\", \"Done\", \"Resolved\", \"Won't Fix\"}, 'dim_defect'[severity] = \"Critical\" || 'dim_defect'[priority] IN {\"P0\", \"P1\", \"Highest\"})",
            "lineageTag": "8521b932-d4ca-4d56-a4e9-5eea798f7a6e"
          }
        ],
