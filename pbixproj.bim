            "name": "P8 Coverage Rate %",
            "expression": "DIVIDE(SUM('vw_p8_release_snapshot'[covered_requirements]), SUM('vw_p8_release_snapshot'[total_requirements]), 0) * 100",
            "lineageTag": "d0e1f2a3-b4c5-6789-defa-789012345680"
          },
          {
            "name": "P8 Automation Rate %",
