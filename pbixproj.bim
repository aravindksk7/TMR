      {
        "name": "fact_defect_link",
        "lineageTag": "f6a7b8c9-d0e1-2345-fabc-345678901234",
        "measures": [
          {
            "name": "Total Defect Links",
            "expression": "COUNTROWS('fact_defect_link')",
            "lineageTag": "f6a7b8c9-d0e1-2345-fabc-345678901235"
          },
          {
            "name": "Open Defects Linked",
            "expression": "CALCULATE(COUNTROWS('fact_defect_link'), 'fact_defect_link'[open_flag] = 1)",
            "lineageTag": "f6a7b8c9-d0e1-2345-fabc-345678901236"
          },
          {
            "name": "Unique Defects",
            "expression": "DISTINCTCOUNT('fact_defect_link'[defect_key])",
            "lineageTag": "f6a7b8c9-d0e1-2345-fabc-345678901237"
          },
          {
            "name": "Impacted Test Runs",
            "expression": "DISTINCTCOUNT('fact_defect_link'[test_run_id])",
