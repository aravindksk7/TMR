        "lineageTag": "42e140ac-b8cb-4ea7-b129-2b168be154a6",
        "measures": [
          {
            "name": "P3 Total Requirements",
            "expression": "DISTINCTCOUNT('vw_p3_requirement_coverage'[issue_key])",
            "lineageTag": "a84b7f47-e991-402b-a8ea-a49011d00317"
          },
          {
            "name": "P3 Covered Requirements",
            "expression": "CALCULATE(DISTINCTCOUNT('vw_p3_requirement_coverage'[issue_key]), 'vw_p3_requirement_coverage'[is_covered] = TRUE())",
            "lineageTag": "6e30d368-a02b-4cc9-83e4-263b0724f944"
