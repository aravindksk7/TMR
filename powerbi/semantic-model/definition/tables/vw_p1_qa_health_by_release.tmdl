	column automated_runs
		dataType: int64
		lineageTag: 325c1b2c-c23f-435f-b705-1c6ac9dbd289
		sourceColumn: automated_runs

	column pass_rate_pct
		dataType: decimal
		lineageTag: 0a706a76-8f19-4b8e-b892-248ae89b1391
		sourceColumn: pass_rate_pct

	partition vw_p1_qa_health_by_release = m
		mode: import
		source =
				let
				    Source = Sql.Database("127.0.0.1,1433", "Reporting_DB"),
				    vw_p1_qa_health_by_release = Source{[Schema="dbo", Item="vw_p1_qa_health_by_release"]}[Data]
				in
